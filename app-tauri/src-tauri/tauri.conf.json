{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "pdf-converter-rust",
  "version": "0.1.0",
  "identifier": "com.govgo.pdf-converter-rust",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:4321",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
        {
          "title": "PDF Converter",
          "width": 550,
          "height": 670,
          "resizable": true,
          "transparent": true,
          "visible": false
        }
      ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
