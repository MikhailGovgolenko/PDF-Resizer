{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "PDF Resizer",
  "version": "1.4.0",
  "identifier": "com.govgolenko.pdf-resizer",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:4321",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
        {
          "title": "PDF Resizer",
          "dragDropEnabled": true,
          "width": 550,
          "height": 670,
          "resizable": true,
          "transparent": true,
          "visible": false
        }
      ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
